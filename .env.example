# 서버
PORT=5174
NODE_ENV=development

# 브라우저→API CORS (쉼표 구분). credentials 사용 시 와일드카드 불가 — Network 의 Origin 과 문자 단위로 일치
# 한글 도메인: Origin 은 보통 Punycode(xn--...) → 그 문자열을 그대로 넣을 것
ADMIN_WEB_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
# 공개 홈페이지(web-home 등)에서 /notices 등 API를 fetch 할 때 — 해당 사이트 Origin 을 쉼표로 추가
# PUBLIC_WEB_ORIGINS=https://www.xn--....kr,http://localhost:3000
# 프로덕션에서 공개 관리자 회원가입(POST /api/v1/admin/auth/register) 허용 시에만 true
# 미설정: 개발은 허용, 프로덕션은 비허용
# ADMIN_REGISTRATION_ENABLED=true
# 다른 도메인 HTTPS 관리자 쿠키(SameSite=None) — Secure 필요
# ADMIN_COOKIE_SAMESITE=none
# 쿠키 Domain (서브도메인 공유 시 예: .example.com). 미설정 시 호스트 기본
# ADMIN_COOKIE_DOMAIN=

# 리버스 프록시(Nginx 등) 뒤에서 IP·HTTPS 판별 시 1
# TRUST_PROXY=1

# 관리자 리프레시: 운영 기본은 httpOnly 쿠키만. JSON body 허용 시 true (레거시 클라이언트)
# ADMIN_ALLOW_REFRESH_BODY=false

# 로그인 시 같은 관리자의 기존 리프레시 토큰 전부 무효화(다른 기기 로그아웃)
# ADMIN_REVOKE_REFRESH_ON_LOGIN=false

# 개발 전용 모의 로그인 라우트를 켤 때만 true — 운영에서는 항상 무시됨(백엔드 정책)
# ADMIN_DEV_MOCK_LOGIN=false

# DB (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ride_db"

# JWT (로그인/회원가입용)
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_at_least_32_chars
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# Kakao (역지오코딩)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 이메일 (상담문의 발송)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="넘버원대리 <your_email@gmail.com>"
CONTACT_EMAIL=receive@example.com

# Redis (나중에 추가)
# REDIS_URL=redis://localhost:6379

# PortOne (결제/카드 연동)
# 콘솔 https://admin.portone.io → 설정 → API 탭에서 발급
PORTONE_API_KEY=your_portone_api_key
PORTONE_API_SECRET=your_portone_api_secret
# Store ID (Flutter portone_config와 동일)
PORTONE_STORE_ID=store-3a52a131-086e-4b5c-9002-1c5696cffee4
# Channel Key (빌링키 결제 시 필요, Flutter portone_config와 동일)
PORTONE_CHANNEL_KEY=channel-key-727e7660-9ec6-4339-a642-1501d9492d34

# OpenAI (AI 자동답변)
OPENAI_API_KEY=your_openai_api_key

# S3 (업로드 프리사인 URL) — EC2에는 IAM 역할 권장, 로컬은 액세스 키 또는 프로파일
AWS_REGION=ap-northeast-2
# AWS 콘솔 버킷 이름과 동일(예: number-one-daeri)
AWS_S3_BUCKET=number-one-daeri
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Presign 서명은 서버의 IAM 역할(또는 위 키)이 필요합니다. 역할/키 없으면 503/500.
# 관리자 웹→S3 직접 PUT 시 버킷 CORS에 관리자 Origin, 메서드 PUT, 헤더 Content-Type 허용